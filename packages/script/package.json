{
  "name": "@link-exchange/script",
  "version": "0.1.0",
  "description": "Link Exchange Badge Delivery SDK — CDN script bundle for direct HTML usage",
  "type": "module",
  "main": "./dist/index.global.js",
  "module": "./dist/index.js",
  "keywords": [
    "cdn",
    "umd",
    "iife",
    "badge",
    "partner",
    "footer",
    "remote-config",
    "sdk",
    "link-exchange",
    "browser",
    "vanilla-js"
  ],
  "author": "Link Exchange Badges",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/link-exchange-badges.git",
    "directory": "packages/script"
  },
  "homepage": "https://yourusername.github.io/link-exchange-badges/guide/html-integration",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,iife --global-name LinkExchange --minify --clean",
    "dev": "tsup src/index.ts --format esm,iife --global-name LinkExchange --watch"
  },
  "dependencies": {
    "@link-exchange/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
